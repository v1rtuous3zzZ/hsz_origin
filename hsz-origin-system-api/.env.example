DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=replace_me
DB_PASSWORD=replace_me
DB_NAME=hsz_origin
JWT_SECRET=replace_with_a_random_secret
JWT_EXPIRE_MINUTES=480
SOURCE_DB_DEFAULT_USER=replace_me
SOURCE_DB_DEFAULT_PASSWORD=replace_me

# 门架读取：同一主机串行，不同门架服务器可并行。
HSZ_ETL_BATCH_SIZE=2000
HSZ_ETL_MAX_WORKERS=4
HSZ_ETL_LIVE_MAX_WORKERS=4
HSZ_ETL_SOURCE_RETRIES=3
HSZ_ETL_SERIALIZE_SOURCE_READS=true
HSZ_ETL_SOURCE_LOCK_TIMEOUT_SECONDS=300
HSZ_ETL_SOURCE_INDEX_LIVE_POLICY=WARN

# 中心库处理失败不会重新读取门架。
HSZ_ETL_CENTER_RETRIES=2
HSZ_ETL_CENTER_WRITE_BATCH_SIZE=10000

# 实时与历史循环。
HSZ_ETL_LIVE_WINDOW_MINUTES=120
HSZ_ETL_POLL_SECONDS=60
HSZ_ETL_SAFETY_DELAY_SECONDS=120
HSZ_ETL_HISTORY_WINDOW_MINUTES=120
HSZ_ETL_HISTORY_MAX_WORKERS=1
HSZ_ETL_HISTORY_SOURCE_BATCH_SIZE=2000
HSZ_ETL_HISTORY_SLEEP_SECONDS=10

# HTTP 手动同步后台任务 worker。
HSZ_ETL_MANUAL_JOB_POLL_SECONDS=5
HSZ_ETL_MANUAL_JOB_STALE_MINUTES=360

HSZ_ETL_SUCCESS_POLICY=replace_me
